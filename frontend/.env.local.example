NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_DEFAULT_KEY=your-supabase-anon-key
SUPABASE_SECRET_KEY=your-supabase-service-role-key
NEXT_PUBLIC_API_BASE_URL=http://localhost:3001

# Dev/demo only. When set to "true" the frontend skips login/signup and
# treats the user as authenticated with a fake demo identity so the UI can
# be inspected without a real Supabase session. Backend calls will not be
# authenticated. Leave unset (or set to "false") for normal auth.
# NEXT_PUBLIC_GARY_SKIP_AUTH=true
